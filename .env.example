# Stage 2 lyrics sources — all optional, pipeline uses whichever keys are set.
# lrclib.net is always tried first and needs no key.
MUSIXMATCH_API_KEY=your_key_here   # paid plan required for synced lyrics
GENIUS_API_KEY=your_key_here       # free at genius.com/api-clients

# Stage 4 ASR
DEEPGRAM_API_KEY=your_key_here

# Stage 5 translation
DEEPL_API_KEY=your_key_here

# Optional pipeline settings
OUTPUT_DIR=output
AUDIO_QUALITY=128
MAX_CONCURRENT_DOWNLOADS=3
MAX_CONCURRENT_API_CALLS=5
